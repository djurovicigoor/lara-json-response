{
    "name": "djurovicigoor/larajsonresponse",
    "description": "Laravel API wrapper for returning JSON response.",
    "license": "MIT",
    "authors": [
        {
            "name": "Djurovic Igor",
            "email": "djurovic.igoor@gmail.com",
            "homepage": "https://djurovic.dev"
        }
    ],
    "homepage": "https://github.com/djurovicigoor/larajsonresponse",
    "keywords": ["Laravel", "LaraJsonResponse", "JSON", "Response", "API"],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.22",
        "orchestra/testbench": "^8.0|^9.6|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "DjurovicIgoor\\LaraJsonResponse\\": "src/"
        },
        "files": [
            "src/Helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "DjurovicIgoor\\LaraJsonResponse\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DjurovicIgoor\\LaraJsonResponse\\LaraJsonResponseServiceProvider"
            ],
            "aliases": {
                "LaraJsonResponse": "DjurovicIgoor\\LaraJsonResponse\\Facades\\LaraJsonResponse"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "format": "vendor/bin/pint",
        "test": "vendor/bin/phpunit"
    }
}
